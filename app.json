{
  "expo": {
    "name": "HealthTracker",
    "slug": "health-tracker",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "healthtracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.healthtracker.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50"
      },
      "package": "com.healthtracker.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "53a81a1a-0304-45db-82f5-a78d921278af"
      }
    },
    "owner": "c-raug"
  }
}
