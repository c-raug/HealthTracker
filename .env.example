# Google Forms feedback integration
# Get these from your Google Form's "Get pre-filled link" > inspect the form action URL
EXPO_PUBLIC_GOOGLE_FORM_ID=your_google_form_id_here
EXPO_PUBLIC_GOOGLE_FORM_ENTRY=entry.your_entry_field_id_here

# GitHub Project board IDs (used by /ci, /cp, /cr, /release-notes skills)
# GH_PROJECT_BOARD_ID: the ProjectV2 node ID — run: gh api graphql -f query='{ viewer { projectsV2(first:10) { nodes { id title } } } }'
# GH_PROJECT_FIELD_ID: the Status single-select field ID on the board
# GH_PROJECT_BACKLOG_OPTION_ID: the single-select option ID for the "Backlog" status
GH_PROJECT_BOARD_ID=your_project_v2_node_id_here
GH_PROJECT_FIELD_ID=your_project_status_field_id_here
GH_PROJECT_BACKLOG_OPTION_ID=your_backlog_option_id_here
