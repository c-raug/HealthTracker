    "@sentry/react-native": "~7.11.0",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.30",
